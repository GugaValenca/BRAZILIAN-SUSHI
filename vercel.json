{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/asgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/api/asgi.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/api/asgi.py"
    },
    {
      "src": "/media/(.*)",
      "dest": "/api/asgi.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
