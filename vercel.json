{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/wsgi.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/api/wsgi.py"
    },
    {
      "source": "/media/(.*)",
      "destination": "/api/wsgi.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
